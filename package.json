{
  "name": "scope-2-calculator",
  "private": true,
  "description": "Unified Scope 1 + Scope 2 assessments (fn + sustally)",
  "scripts": {
    "dev:fn": "npm run dev --prefix fn",
    "dev:sustally": "npm run dev --prefix sustally",
    "test:engine": "npm run test:engine --prefix sustally",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "smoke": "bash scripts/smoke-unified.sh",
    "migrate:bookings": "npm run migrate:bookings --prefix sustally",
    "migrate:bookings:dry": "npm run migrate:bookings:dry --prefix sustally"
  },
  "devDependencies": {
    "@playwright/test": "1.56.1"
  }
}
