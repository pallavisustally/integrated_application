DATABASE_URL=mongodb://127.0.0.1/sustally
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Frontend (fn app) — user-facing links in emails & assessment URLs. No trailing slash.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend (this sustally app). No trailing slash.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# Standalone admin dashboard. No trailing slash.
ADMIN_DASHBOARD_URL=http://localhost:3002

# Comma-separated browser origins allowed to call this API (optional; defaults include localhost + known Vercel URLs).
# CORS_ORIGINS=http://localhost:3000,https://integrated-application-fn.vercel.app,https://new-rho-plum.vercel.app
